{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"],
}
